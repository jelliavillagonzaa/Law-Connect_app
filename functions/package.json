{
  "name": "law-connect-functions",
  "description": "Court email ingest → calendar_events (Law Connect)",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "npm run build && firebase deploy --only functions",
    "deploy:imap": "npm run build && firebase deploy --only functions:imapCourtEmailIngest,functions:imapCourtEmailManual,functions:onCourtEmailQueueNotify,functions:courtEmailIngest,functions:processCourtEmailQueue",
    "lint": "eslint --ext .js,.ts src",
    "test:philsms": "node scripts/test-philsms.mjs"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.3.0",
    "googleapis": "^171.4.0",
    "imapflow": "^1.2.16",
    "mailparser": "^3.9.4",
    "nodemailer": "^6.9.16",
    "pdf-parse": "^1.1.1",
    "sharp": "^0.34.5",
    "twilio": "^5.9.0"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.5.0"
  },
  "private": true
}
